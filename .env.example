# =============================================================================
# Plane Environment Variables Template
# =============================================================================
#
# COPY THIS FILE TO apps/api/.env AND FILL IN VALUES.
# NEVER COMMIT .env TO VERSION CONTROL.
#
# The .env file is auto-populated by:
#   - Doppler:    doppler run -- bun dev
#   - direnv:     echo 'eval "$(doppler env)"' >> .envrc
#   - Docker:     passed via docker-compose environment: section
#
# For local development without Doppler, copy to .env:
#   cp .env.example apps/api/.env
#   # Fill in values, then:
#   cd apps/api && source .venv/bin/activate && python manage.py runserver
#
# =============================================================================

# --- Django (REQUIRED) ---
SECRET_KEY=                    # Generate: openssl rand -hex 64
DJANGO_SETTINGS_MODULE=plane.settings.local

# --- Database (REQUIRED) ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=
POSTGRES_DB=plane
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=plane
POSTGRES_PASSWORD=              # Generate: openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 24

# --- Redis (REQUIRED) ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Web URLs ---
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:8000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Debug ---
DEBUG=1

# --- AWS S3 (optional, for file uploads) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=http://localhost:9000
AWS_S3_BUCKET_NAME=uploads

# --- RabbitMQ (REQUIRED for background tasks) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/

# --- Optional Services ---
SENTRY_DSN=
POSTHOG_API_KEY=
